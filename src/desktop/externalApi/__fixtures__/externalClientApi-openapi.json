            "$ref": "#/components/responses/Forbidden"
          },
          "421": {
            "$ref": "#/components/responses/MisdirectedRequest"
          },
          "500": {
            "$ref": "#/components/responses/ServerError"
          },
          "503": {
            "$ref": "#/components/responses/ServiceUnavailable"
          }
        }
      }
    },
