            <format attr='size' value='1.3733149766921997' />
          </style-rule>
        </style>
      </pane>
    </panes>
    <rows>[{{DATASOURCE}}].[sum:Sales:qk]</rows>
    <cols>[{{DATASOURCE}}].[tmn:Order Date:qk]</cols>
  </table>
