        <column caption='Men' datatype='real' name='[Calculation_2084392578408062979]' role='measure' type='quantitative'>
          <calculation class='tableau' formula='SUM(if [Gender]=&apos;Men&apos; THEN [Value]
END)/SUM([Value])' />
