          <table-calc field='[{{DATASOURCE}}].[Calculation_44402728363008000]' ordering-type='Field'>
            <order field='[{{DATASOURCE}}].[Sub-Category]' />
            <order field='[{{DATASOURCE}}].[yr:Order Date:ok]' />
          </table-calc>
        </column-instance>
        <column-instance column='[Calculation_44402728364228614]' derivation='User' name='[usr:Calculation_44402728364228614:qk:22]' pivot='key' type='quantitative'>
          <table-calc ordering-type='Rows' />
          <table-calc field='[{{DATASOURCE}}].[Calculation_44402728363352065]' ordering-type='Rows' />
          <table-calc field='[{{DATASOURCE}}].[Calculation_44402728363651076]' ordering-field='[{{DATASOURCE}}].[Sub-Category]' ordering-type='Field' />
