<workbook>
  <worksheets>
    <worksheet name='{{TITLE}}'>
  <layout-options>
    <caption>
      <formatted-text>
        <run>From  Kevin M. Knorpp @ </run>
        <run auto-url='true' hyperlink='tabdoc:load-url url=&amp;quot;https://typicalanalytical.com/2017/09/16/how-to-build-this-chart-type-in-tableau/amp/&amp;quot;'>https://typicalanalytical.com/2017/09/16/how-to-build-this-chart-type-in-tableau/amp/</run>
